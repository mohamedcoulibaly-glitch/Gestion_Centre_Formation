using System; // Importation du namespace System
using System.Windows.Forms; // Pour les formulaires Windows
using System.Drawing; // Pour les couleurs et les polices
using CentreFormation.Services; // Importation des services
using CentreFormation.Models; // Importation des modèles
using CentreFormation.UI; // Importation de la configuration de thème

namespace CentreFormation.Forms // Namespace du projet
{
    public partial class FormAjoutFormateur : Form // Formulaire pour ajouter un formateur
    {
        private GestionCentre _gestion; // Référence à la gestion du centre
        public Formateur FormateurCree { get; private set; } // Propriété pour le formateur créé

        // Champs privés pour les contrôles du formulaire
        private TextBox txtId = new TextBox(); // Champ texte pour l'ID
        private TextBox txtNom = new TextBox(); // Champ texte pour le nom
        private TextBox txtPrenom = new TextBox(); // Champ texte pour le prénom
        private NumericUpDown nudAge = new NumericUpDown(); // Sélecteur numérique pour l'âge
        private TextBox txtSpecialite = new TextBox(); // Champ texte pour la spécialité
        private TextBox txtModule = new TextBox(); // Champ texte pour le module
        private NumericUpDown nudSalaire = new NumericUpDown(); // Sélecteur numérique pour le salaire

        public FormAjoutFormateur(GestionCentre gestion)
        {
            _gestion = gestion; // Initialise la référence à la gestion
            InitializeComponent(); // Initialise les contrôles du formulaire
            txtId.Text = _gestion.NouvelIdFormateur().ToString(); // Affiche le nouvel ID généré
            txtId.ReadOnly = true; // Le champ est en lecture seule (ID auto-généré)
        }

        private void InitializeComponent()
        {
